@{
    ViewData["Title"] = "Trang Chủ";
    var prodCategories = ViewBag.ProductCategories as List<CMS.Data.Entities.CategoryProduct>;
    var postCategories = ViewBag.PostCategories as List<CMS.Data.Entities.Category>;
    var products = ViewBag.LatestProducts as List<CMS.Data.Entities.Product>;
    var posts = ViewBag.LatestPosts as List<CMS.Data.Entities.Post>;
}

<div class="p-5 mb-4 bg-dark text-white rounded-3" style="background: linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.6)), url('https://images.unsplash.com/photo-1618005182384-a83a8bd57fbe?q=80&w=1200&auto=format&fit=cover') no-repeat center center; background-size: cover;">
    <div class="container-fluid py-5 text-center">
        <h1 class="display-5 fw-bold text-uppercase text-info">CMS PORTAL HỆ THỐNG</h1>
        <p class="col-md-8 mx-auto fs-5 text-light opacity-75">Khám phá không gian Decor phòng ngủ lý tưởng và thế giới mô hình siêu xe đỉnh cao cùng tin tức công nghệ mới nhất.</p>
        <a href="/Product" class="btn btn-info text-dark fw-bold btn-lg px-4 shadow">Xem tất cả sản phẩm</a>
    </div>
</div>

<div class="container my-5">
    <div class="mb-5">
        <h3 class="fw-bold text-dark text-uppercase mb-3"><i class="bi bi-tags-fill text-info me-2"></i> Danh mục sản phẩm</h3>
        <div class="row row-cols-2 row-cols-md-4 g-3">
            @if (prodCategories != null && prodCategories.Any())
            {
                foreach (var cat in prodCategories)
                {
                    <div class="col">
                        <a href="/ProductCategory/ViewCategory/@cat.Id" class="card h-100 border-0 shadow-sm text-decoration-none bg-white p-3 text-center rounded-3 border-bottom border-info border-3 transition-hover" style="transition: transform 0.2s;">
                            <div class="card-body p-2">
                                <i class="bi bi-box-seam fs-2 text-info mb-2 d-block"></i>
                                <h6 class="card-title fw-bold text-dark mb-1 text-truncate">@cat.Name</h6>
                                <small class="text-muted text-truncate d-block">@cat.Description</small>
                            </div>
                        </a>
                    </div>
                }
            }
            else
            {
                <p class="text-muted ms-2">Chưa có danh mục sản phẩm nào.</p>
            }
        </div>
    </div>

    <div class="mb-5">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h3 class="fw-bold text-dark text-uppercase m-0"><i class="bi bi-fire text-danger me-2"></i> Sản phẩm mới nhất</h3>
            <a href="/Product" class="text-decoration-none text-info fw-semibold small">Xem thêm &rarr;</a>
        </div>
        <div class="row row-cols-1 row-cols-md-4 g-4">
            @if (products != null)
            {
                foreach (var item in products)
                {
                    string pUrl = (item.ImageUrl ?? "").Trim();
                    string pSrc = pUrl.StartsWith("http") ? pUrl : "/uploads/" + (string.IsNullOrEmpty(pUrl) ? "den.jpg" : pUrl);

                    <div class="col">
                        <div class="card h-100 shadow-sm border-0 position-relative rounded-3 overflow-hidden">
                            <span class="position-absolute top-0 start-0 badge bg-info text-dark m-2 fw-bold">@item.CategoryProduct?.Name</span>
                            <img src="@pSrc" class="card-img-top" alt="@item.Name" style="height: 180px; object-fit: cover;" onerror="this.onerror=null; this.src='/uploads/den.jpg';">
                            <div class="card-body d-flex flex-column text-center bg-white">
                                <h6 class="card-title fw-bold text-dark text-truncate mb-2">@item.Name</h6>
                                <p class="text-danger fw-bold fs-5 mt-auto mb-3">@String.Format("{0:N0}", item.Price) đ</p>
                                <a href="/Product/Detail/@item.Id" class="btn btn-outline-dark btn-sm w-100 fw-semibold rounded-2">Xem chi tiết</a>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-8">
            <h3 class="fw-bold text-dark text-uppercase mb-3"><i class="bi bi-newspaper text-primary me-2"></i> Tin tức dự án nổi bật</h3>
            <div class="d-flex flex-column gap-3">
                @if (posts != null)
                {
                    foreach (var post in posts)
                    {
                        string postUrl = (post.ImageUrl ?? "").Trim();
                        string postSrc = postUrl.StartsWith("http") ? postUrl : "/uploads/" + (string.IsNullOrEmpty(postUrl) ? "banner.jpg" : postUrl);

                        <div class="card border-0 shadow-sm rounded-3 overflow-hidden">
                            <div class="row g-0">
                                <div class="col-4">
                                    <img src="@postSrc" class="img-fluid h-100 w-100" style="object-fit: cover; min-height: 120px;" onerror="this.onerror=null; this.src='/uploads/banner.jpg';">
                                </div>
                                <div class="col-8">
                                    <div class="card-body py-2 px-3">
                                        <span class="badge bg-secondary bg-opacity-10 text-secondary small mb-1">@post.Category?.Name</span>
                                        <h6 class="card-title fw-bold mb-1 text-dark text-truncate">@post.Title</h6>
                                        <p class="card-text text-muted small text-truncate-2 mb-2" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; white-space: normal;">@post.Content</p>
                                        <small class="text-black-50"><i class="bi bi-calendar3 me-1"></i> @post.CreatedDate.ToString("dd/MM/yyyy")</small>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>

        <div class="col-md-4">
            <h3 class="fw-bold text-dark text-uppercase mb-3"><i class="bi bi-folder-fill text-warning me-2"></i> Chủ đề tin tức</h3>
            <div class="list-group shadow-sm border-0 rounded-3 overflow-hidden">
                @if (postCategories != null && postCategories.Any())
                {
                    foreach (var cat in postCategories)
                    {
                        <a href="/Post/Category/@cat.Id" class="list-group-item list-group-item-action border-0 d-flex justify-content-between align-items-center py-3">
                            <div class="fw-semibold text-secondary"><i class="bi bi-chevron-right text-warning small me-2"></i> @cat.Name</div>
                            <span class="badge bg-warning bg-opacity-25 text-warning rounded-pill small"><i class="bi bi-collection"></i></span>
                        </a>
                    }
                }
                else
                {
                    <div class="list-group-item text-muted">Chưa có chủ đề tin tức nào.</div>
                }
            </div>
        </div>
    </div>
</div>

<style>
    /* Hiệu ứng zoom nhẹ khi rê chuột vào các ô danh mục sản phẩm cho đẹp mắt */
    .transition-hover:hover {
        transform: translateY(-5px);
        box-shadow: 0 .5rem 1rem rgba(0,0,0,.15) !important;
    }
</style>