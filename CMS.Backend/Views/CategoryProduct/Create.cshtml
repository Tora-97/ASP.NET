@model CMS.Data.Entities.CategoryProduct
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Thêm mới danh mục";
}

<div class="container my-4" style="max-width: 600px;">
    <div class="card shadow border-0">
        <div class="card-header bg-success text-white fw-bold py-3">
            <h5 class="mb-0"><i class="bi bi-plus-circle"></i> THÊM DANH MỤC SẢN PHẨM MỚI</h5>
        </div>
        <div class="card-body p-4">
            <form action="/CategoryProduct/Create" method="post">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label class="form-label fw-bold">Tên Danh Mục <span class="text-danger">*</span></label>
                    <input type="text" name="Name" class="form-control" required placeholder="Nhập tên danh mục (Ví dụ: Đồ Decor)">
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Mô Tả</label>
                    <textarea name="Description" class="form-control" rows="4" placeholder="Nhập mô tả ngắn gọn về nhóm sản phẩm này"></textarea>
                </div>

                <div class="d-flex gap-2 justify-content-end border-top pt-3">
                    <a href="/CategoryProduct/Index" class="btn btn-secondary">Quay lại</a>
                    <button type="submit" class="btn btn-success px-4">Lưu Danh Mục</button>
                </div>
            </form>
        </div>
    </div>
</div>