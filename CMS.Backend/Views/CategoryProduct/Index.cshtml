@model List<CMS.Data.Entities.CategoryProduct>
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Quản lý danh mục sản phẩm";
}

<div class="container-fluid my-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="text-secondary fw-bold"><i class="bi bi-folder"></i> Quản Lý Danh Mục Sản Phẩm</h2>
        <a href="/CategoryProduct/Create" class="btn btn-success fw-bold"><i class="bi bi-plus-circle"></i> Thêm Danh Mục Mới</a>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <table class="table table-hover table-striped mb-0 align-middle">
                <thead class="table-dark">
                    <tr>
                        <th style="width: 10%">Mã ID</th>
                        <th style="width: 30%">Tên Danh Mục</th>
                        <th style="width: 40%">Mô Tả Chi Tiết</th>
                        <th style="width: 20%" class="text-center">Hành Động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-bold text-muted">#@item.Id</td>
                            <td class="fw-bold text-primary">@item.Name</td>
                            <td class="text-secondary text-truncate" style="max-width: 300px;">@item.Description</td>
                            <td class="text-center">
                                <a href="/CategoryProduct/Edit/@item.Id" class="btn btn-warning btn-sm fw-bold"><i class="bi bi-pencil-square"></i> Sửa</a>
                                <a href="/CategoryProduct/Delete/@item.Id" class="btn btn-danger btn-sm fw-bold" onclick="return confirm('Bạn có chắc chắn muốn xóa danh mục này không?')"><i class="bi bi-trash"></i> Xóa</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>