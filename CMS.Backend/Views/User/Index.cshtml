@model IEnumerable<CMS.Data.Entities.User>
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Quản lý thành viên";
}

<div class="container mt-4">
    <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-center border-bottom pb-3 mb-4 gap-2">
        <div>
            <h3 class="text-dark fw-bold mb-1"><i class="bi bi-people-fill text-primary"></i> QUẢN LÝ THÀNH VIÊN</h3>
            <p class="text-muted small mb-0">Danh sách các tài khoản có quyền truy cập quản trị hệ thống CMS</p>
        </div>
        <a asp-action="Create" class="btn btn-success fw-semibold shadow-sm align-self-start align-self-sm-center">
            <i class="bi bi-person-plus-fill"></i> Thêm thành viên mới
        </a>
    </div>

    <div class="card shadow-sm border-0" style="border-radius: 0.5rem;">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light text-secondary small fw-bold">
                    <tr>
                        <th class="text-center py-3" style="width: 80px">ID</th>
                        <th class="py-3" style="width: 220px">TÊN ĐĂNG NHẬP</th>
                        <th class="py-3">HỌ VÀ TÊN</th>
                        <th class="py-3" style="width: 200px">QUYỀN HẠN</th>
                        <th class="text-center py-3" style="width: 180px">THAO TÁC</th>
                    </tr>
                </thead>
                <tbody class="border-top-0">
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td class="text-center fw-bold text-secondary">#@user.Id</td>

                            <td>
                                <span class="d-inline-flex align-items-center gap-2">
                                    <div class="bg-light rounded-circle d-flex align-items-center justify-content-center" style="width: 32px; height: 32px;">
                                        <i class="bi bi-person text-secondary"></i>
                                    </div>
                                    <strong class="text-dark">@user.Username</strong>
                                </span>
                            </td>

                            <td class="fw-medium text-secondary">@user.FullName</td>

                            <td>
                                @if (user.Role == "Administrator" || user.Role == "Admin")
                                {
                                    <span class="badge bg-danger bg-opacity-10 text-danger px-2.5 py-1.5 fw-semibold" style="border-radius: 0.375rem;">
                                        <i class="bi bi-shield-lock-fill me-1"></i> Quản trị viên
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-info bg-opacity-10 text-info-emphasis px-2.5 py-1.5 fw-semibold" style="border-radius: 0.375rem;">
                                        <i class="bi bi-pencil-square me-1"></i> Biên tập viên
                                    </span>
                                }
                            </td>

                            <td class="text-center">
                                <div class="d-inline-flex gap-1">
                                    <a asp-action="Edit" asp-route-id="@user.Id"
                                       class="btn btn-sm btn-outline-warning d-flex align-items-center gap-1 px-2 py-1">
                                        <i class="bi bi-pencil"></i> Sửa
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@user.Id"
                                       class="btn btn-sm btn-outline-danger d-flex align-items-center gap-1 px-2 py-1"
                                       onclick="return confirm('Bạn có chắc chắn muốn xóa vĩnh viễn quyền truy cập của tài khoản 【@user.Username】 này không?')">
                                        <i class="bi bi-trash"></i> Xóa
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>