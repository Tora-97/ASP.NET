@{
    Layout = "_LayoutAdmin"; // Đảm bảo bạn đã có LayoutAdmin
    ViewData["Title"] = "Bảng điều khiển";
}

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-12">
            <h2 class="fw-bold">Chào mừng trở lại, @ViewBag.AdminName!</h2>
            <p class="text-muted">Đây là hệ thống quản trị nội dung của bạn.</p>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-md-4">
            <div class="card bg-primary text-white p-3 shadow-sm">
                <h5>Bài viết mới</h5>
                <h2 class="fw-bold">12</h2>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-success text-white p-3 shadow-sm">
                <h5>Đơn hàng chờ</h5>
                <h2 class="fw-bold">5</h2>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-warning text-dark p-3 shadow-sm">
                <h5>Khách hàng</h5>
                <h2 class="fw-bold">89</h2>
            </div>
        </div>
    </div>
</div>