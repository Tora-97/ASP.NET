@model IEnumerable<CMS.Data.Entities.Customer>
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Quản lý Khách hàng";
}

<div class="container-fluid mt-4">
    <h3 class="fw-bold text-dark mb-4"><i class="bi bi-person-badge me-2 text-primary"></i> DANH SÁCH KHÁCH HÀNG</h3>
    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light text-uppercase small">
                    <tr>
                        <th class="py-3 ps-4">ID</th>
                        <th>Họ Tên</th>
                        <th>Email</th>
                        <th>Điện Thoại</th>
                        <th>Địa Chỉ</th>
                        <th class="text-center">Thao Tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4 fw-bold text-secondary">#@item.Id</td>
                            <td>@item.FullName</td>
                            <td>@item.Email</td>
                            <td>@item.Phone</td>
                            <td class="text-truncate" style="max-width: 200px;">@item.Address</td>
                            <td class="text-center">
                                <a href="/Customer/Delete/@item.Id" class="btn btn-sm btn-outline-danger" onclick="return confirm('Xóa khách hàng này?')"><i class="bi bi-trash"></i></a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>