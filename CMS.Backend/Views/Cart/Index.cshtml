@model List<CMS.Backend.Models.CartItem>
@{
    ViewData["Title"] = "Giỏ Hàng Của Bạn";
    decimal totalCartAmount = Model.Sum(item => item.TotalPrice);
}

<div class="container my-5">
    <h1 class="mb-4 fw-bold text-uppercase border-bottom pb-2 text-dark"><i class="bi bi-cart3"></i> Giỏ Hàng</h1>

    @if (Model.Count == 0)
    {
        <div class="card p-5 text-center shadow-sm border-0 rounded-3">
            <div class="card-body">
                <i class="bi bi-bag-x-fill text-muted" style="font-size: 4rem;"></i>
                <h3 class="mt-3 text-secondary fw-bold">Giỏ hàng của bạn đang trống rỗng!</h3>
                <p class="text-muted">Hãy chọn cho mình những món đồ Decor phòng ngủ hoặc Siêu xe ưng ý nhé.</p>
                <a href="/Product" class="btn btn-primary btn-lg mt-2 px-5 fw-bold">Tiếp tục mua sắm</a>
            </div>
        </div>
    }
    else
    {
        <div class="row g-4">
            <div class="col-lg-8">
                <div class="card shadow-sm border-0 rounded-3 overflow-hidden">
                    <div class="card-body p-0">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-dark">
                                <tr>
                                    <th style="width: 15%">Hình ảnh</th>
                                    <th style="width: 35%">Tên sản phẩm</th>
                                    <th style="width: 15%">Đơn giá</th>
                                    <th style="width: 15%">Số lượng</th>
                                    <th style="width: 15%">Thành tiền</th>
                                    <th style="width: 5%"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td>
                                            <img src="/uploads/@(string.IsNullOrEmpty(item.ImageUrl) ? "den.jpg" : item.ImageUrl)" class="img-thumbnail rounded" style="width: 70px; height: 70px; object-fit: cover;">
                                        </td>
                                        <td>
                                            <h6 class="mb-0 fw-bold text-dark text-truncate" style="max-width: 250px;">@item.ProductName</h6>
                                        </td>
                                        <td class="fw-semibold text-secondary">@String.Format("{0:N0}", item.Price) đ</td>
                                        <td>
                                            <form action="/Cart/UpdateQuantity" method="post" class="d-flex align-items-center">
                                                <input type="hidden" name="productId" value="@item.ProductId" />
                                                <input type="number" name="quantity" value="@item.Quantity" class="form-control form-control-sm text-center fw-bold me-1" style="width: 60px;" min="1" onchange="this.form.submit()">
                                            </form>
                                        </td>
                                        <td class="text-danger fw-bold">@String.Format("{0:N0}", item.TotalPrice) đ</td>
                                        <td class="text-center">
                                            <a href="/Cart/RemoveItem?productId=@item.ProductId" class="text-muted hover-danger" onclick="return confirm('Xóa sản phẩm này khỏi giỏ hàng?')">
                                                <i class="bi bi-trash3-fill text-danger fs-5"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card border-0 shadow-sm rounded-3 bg-light p-3">
                    <div class="card-body">
                        <h4 class="card-title fw-bold mb-4 text-secondary">TÓM TẮT ĐƠN HÀNG</h4>
                        <div class="d-flex justify-content-between mb-3 border-bottom pb-2">
                            <span class="text-muted">Tổng số món:</span>
                            <span class="fw-bold text-dark">@Model.Sum(i => i.Quantity) sản phẩm</span>
                        </div>
                        <div class="d-flex justify-content-between mb-4">
                            <span class="fs-5 fw-bold">Tổng thanh toán:</span>
                            <span class="fs-4 fw-bold text-danger">@String.Format("{0:N0}", totalCartAmount) VNĐ</span>
                        </div>

                        <div class="d-grid gap-2">
                            <button class="btn btn-success btn-lg fw-bold py-3" onclick="alert('Hệ thống đang chuẩn bị kết nối với môi trường kiểm thử VNPAY Sandbox để tiến hành thanh toán!')">
                                <i class="bi bi-credit-card-2-back-fill"></i> TIẾN HÀNH ĐẶT HÀNG
                            </button>
                            <a href="/Product" class="btn btn-outline-dark fw-bold py-2">Tiếp tục chọn thêm đồ</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>