@model CMS.Data.Entities.Product
@{
    ViewData["Title"] = Model.Name;
}

<div class="container my-5 py-5">
    <div class="row g-5">
        <div class="col-md-6">
            <img src="/uploads/@(string.IsNullOrEmpty(Model.ImageUrl) ? "den.jpg" : Model.ImageUrl)" class="img-fluid rounded-3 shadow-sm w-100" alt="@Model.Name" style="max-height: 450px; object-fit: cover;">
        </div>

        <div class="col-md-6">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/" class="text-decoration-none text-muted">Trang chủ</a></li>
                    <li class="breadcrumb-item"><a href="/Product" class="text-decoration-none text-muted">Sản phẩm</a></li>
                    <li class="breadcrumb-item active" aria-current="page">@Model.CategoryProduct?.Name</li>
                </ol>
            </nav>

            <h1 class="display-6 fw-bold mb-3">@Model.Name</h1>
            <p class="text-danger fs-3 fw-bold mb-4">Giá bán: @String.Format("{0:N0}", Model.Price) VNĐ</p>

            <div class="border-top border-bottom py-3 mb-4">
                <h5 class="fw-bold">Mô tả sản phẩm:</h5>
                <p class="text-secondary mb-0">@Model.Description</p>
            </div>

            <div class="mb-4">
                <p class="text-muted">Trạng thái kho: <span class="text-success fw-bold">Còn hàng (@Model.StockQuantity sản phẩm)</span></p>
            </div>

            <a href="/Cart/AddToCart?productId=@Model.Id" class="btn btn-dark btn-lg px-5 py-3 w-100 fw-bold shadow-sm">
                <i class="bi bi-cart-plus-fill me-2"></i> THÊM VÀO GIỎ HÀNG
            </a>
        </div>
    </div>
</div>