@model IEnumerable<CMS.Data.Entities.OrderDetail>
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Chi tiết đơn hàng";
}

<div class="container mt-4">
    <a href="/Order/Index" class="btn btn-outline-secondary mb-3"><i class="bi bi-arrow-left"></i> Quay lại đơn hàng</a>
    <div class="card shadow-sm border-0">
        <div class="card-header bg-white py-3">
            <h5 class="fw-bold mb-0">Chi tiết sản phẩm đơn hàng #@Model.FirstOrDefault()?.OrderId</h5>
        </div>
        <div class="card-body p-0">
            <table class="table align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Sản Phẩm</th>
                        <th>Đơn Giá</th>
                        <th>Số Lượng</th>
                        <th>Thành Tiền</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <img src="@item.Product?.ImageUrl" style="width: 40px; height: 40px; object-fit: cover;" class="rounded me-2" />
                                @item.Product?.Name
                            </td>
                            <td>@item.UnitPrice.ToString("N0") đ</td>
                            <td>@item.Quantity</td>
                            <td class="fw-bold">@((item.Quantity * item.UnitPrice).ToString("N0")) đ</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>