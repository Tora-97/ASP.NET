@model CMS.Data.Entities.Category
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Chỉnh sửa danh mục";
}

<div class="container mt-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-warning text-dark py-3">
            <h5 class="mb-0 fw-bold"><i class="bi bi-pencil-square me-2"></i> CHỈNH SỬA DANH MỤC</h5>
        </div>
        <div class="card-body p-4">
            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="Id" />
                <div class="mb-3">
                    <label class="form-label fw-semibold">Tên danh mục:</label>
                    <input asp-for="Name" class="form-control" required />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Mô tả:</label>
                    <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                </div>
                <hr class="opacity-25" />
                <div class="d-flex justify-content-end gap-2">
                    <a asp-action="Index" class="btn btn-outline-secondary px-4">Hủy bỏ</a>
                    <button type="submit" class="btn btn-warning text-dark px-4 fw-bold">Cập nhật thay đổi</button>
                </div>
            </form>
        </div>
    </div>
</div>