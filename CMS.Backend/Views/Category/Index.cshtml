@model IEnumerable<CMS.Data.Entities.Category>
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Quản lý danh mục bài viết";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold text-dark mb-0"><i class="bi bi-folder2-open text-primary me-2"></i> DANH SÁCH DANH MỤC</h4>
    <a href="/Category/Create" class="btn btn-primary fw-bold shadow-sm"><i class="bi bi-plus-circle me-1"></i> THÊM MỚI</a>
</div>

<div class="table-responsive bg-white rounded-3 shadow-sm p-3">
    <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
            <tr>
                <th width="80">Mã ID</th>
                <th>Tên danh mục</th>
                <th>Mô tả chi tiết</th>
                <th width="180" class="text-center">Hành động</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td class="fw-bold text-secondary">#@item.Id</td>
                    <td class="fw-bold text-dark">@item.Name</td>
                    <td class="text-muted small">@item.Description</td>
                    <td class="text-center">
                        <a href="/Category/Edit/@item.Id" class="btn btn-warning btn-sm text-dark fw-semibold me-1">
                            <i class="bi bi-pencil-square"></i> Sửa
                        </a>
                        <a href="/Category/Delete/@item.Id" class="btn btn-danger btn-sm fw-semibold" onclick="return confirm('Bạn chắc chắn muốn xóa danh mục này?')">
                            <i class="bi bi-trash"></i> Xóa
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>