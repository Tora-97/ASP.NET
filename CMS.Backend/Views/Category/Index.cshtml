@model CMS.Data.Entities.Category
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Chỉnh sửa danh mục";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-6">
            
            <div class="card shadow-sm border-0" style="border-radius: 0.75rem;">
                <div class="card-header bg-warning text-dark py-3" style="border-top-left-radius: 0.75rem; border-top-right-radius: 0.75rem;">
                    <h5 class="mb-0 fw-bold"><i class="bi bi-pencil-square me-2"></i> CHỈNH SỬA DANH MỤC</h5>
                </div>
                
                <div class="card-body p-4">
                    <form asp-action="Edit" method="post">
                        <input type="hidden" asp-for="Id" />

                        <div class="mb-3">
                            <label class="form-label fw-semibold text-secondary">Tên danh mục:</label>
                            <input asp-for="Name" class="form-control" placeholder="Nhập tên danh mục..." required />
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-semibold text-secondary">Mô tả chi tiết:</label>
                            <textarea asp-for="Description" class="form-control" rows="4" placeholder="Cập nhật lại mô tả..."></textarea>
                        </div>

                        <hr class="text-muted opacity-25 mb-4" />

                        <div class="d-flex justify-content-end gap-2">
                            <a asp-action="Index" class="btn btn-outline-secondary px-4 fw-semibold">
                                <i class="bi bi-arrow-left-short"></i> Quay lại
                            </a>
                            <button type="submit" class="btn btn-warning text-dark px-4 fw-bold shadow-sm">
                                <i class="bi bi-check-circle"></i> Cập nhật thay đổi
                            </button>
                        </div>

                    </form>
                </div>
            </div> </div>
    </div>
</div>