@model CMS.Data.Entities.Category
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Thêm mới danh mục";
}

<div class="container mt-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-primary text-white py-3">
            <h5 class="mb-0 fw-bold"><i class="bi bi-plus-circle me-2"></i> THÊM DANH MỤC MỚI</h5>
        </div>
        <div class="card-body p-4">
            <form asp-action="Create" method="post">
                <div class="mb-3">
                    <label class="form-label fw-semibold">Tên danh mục:</label>
                    <input asp-for="Name" class="form-control" placeholder="Nhập tên danh mục..." required />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Mô tả:</label>
                    <textarea asp-for="Description" class="form-control" rows="4" placeholder="Nhập mô tả..."></textarea>
                </div>
                <hr class="opacity-25" />
                <div class="d-flex justify-content-end gap-2">
                    <a asp-action="Index" class="btn btn-outline-secondary px-4">Quay lại</a>
                    <button type="submit" class="btn btn-primary px-4 fw-bold">Lưu danh mục</button>
                </div>
            </form>
        </div>
    </div>
</div>