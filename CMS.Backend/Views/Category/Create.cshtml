@model CMS.Data.Entities.Post
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Thêm mới bài viết";
}

<div class="container mt-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-primary text-white py-3">
            <h5 class="mb-0 fw-bold"><i class="bi bi-plus-circle me-2"></i> THÊM BÀI VIẾT MỚI</h5>
        </div>
        <div class="card-body p-4">
            <form asp-action="Create" method="post" enctype="multipart/form-data">

                <div class="mb-3">
                    <label class="form-label fw-semibold">Tiêu đề bài viết:</label>
                    <input asp-for="Title" class="form-control" placeholder="Nhập tiêu đề..." required />
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Danh mục:</label>
                    <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.CategoryList" required>
                        <option value="">-- Chọn danh mục bài viết --</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Hình ảnh đại diện:</label>
                    <input type="file" name="uploadImage" id="imageInput" class="form-control" accept="image/*" />

                    <div class="mt-3">
                        <img id="imagePreview" src="https://via.placeholder.com/200x120?text=No+Image"
                             class="img-thumbnail shadow-sm d-block" style="max-width: 250px; height: auto;" />
                    </div>
                </div>

                <hr class="opacity-25" />
                <div class="d-flex justify-content-end gap-2">
                    <a asp-action="Index" class="btn btn-outline-secondary px-4">Quay lại</a>
                    <button type="submit" class="btn btn-primary px-4 fw-bold">Đăng bài viết</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // JavaScript lắng nghe sự kiện chọn file từ thiết bị để lập tức hiển thị lên màn hình
        document.getElementById('imageInput').addEventListener('change', function (e) {
            const preview = document.getElementById('imagePreview');
            const file = e.target.files[0];
            if (file) {
                preview.src = URL.createObjectURL(file);
            }
        });
    </script>
}