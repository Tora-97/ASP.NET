@using Microsoft.AspNetCore.Http
@using System.Text.Json
@using CMS.Backend.Models
@inject IHttpContextAccessor HttpContextAccessor
@{
    // Đọc số lượng sản phẩm trong giỏ hàng từ Session để hiển thị lên badge
    int cartCount = 0;
    var sessionData = HttpContextAccessor.HttpContext?.Session.GetString("UserCart");
    if (!string.IsNullOrEmpty(sessionData))
    {
        var cart = JsonSerializer.Deserialize<List<CartItem>>(sessionData);
        if (cart != null)
        {
            cartCount = cart.Sum(item => item.Quantity);
        }
    }
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CMS Portal</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/CMS.Backend.styles.css" asp-append-version="true" />
</head>
<body class="bg-light d-flex flex-column min-height-100" style="min-height: 100vh;">

    <header class="sticky-top">
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark bg-dark border-bottom shadow-sm py-2">
            <div class="container">
                <a class="navbar-brand fw-bold text-info" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-journal-code"></i> CMS PORTAL
                </a>
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-white-50 px-3" asp-area="" asp-controller="Home" asp-action="Index">Trang chủ</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white-50 px-3" asp-area="" asp-controller="Home" asp-action="Privacy">Chính sách bảo mật</a>
                        </li>
                    </ul>

                    <ul class="navbar-nav align-items-center gap-3">
                        <li class="nav-item">
                            <a href="/Cart" class="nav-link text-white position-relative px-2">
                                <i class="bi bi-cart3 fs-4 text-info"></i>
                                @if (cartCount > 0)
                                {
                                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size: 0.7rem;">
                                        @cartCount
                                    </span>
                                }
                                else
                                {
                                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-secondary" style="font-size: 0.7rem;">
                                        0
                                    </span>
                                }
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="btn btn-outline-info btn-sm px-3 fw-semibold" asp-controller="Category" asp-action="Index">
                                <i class="bi bi-speedometer"></i> Trang Quản Trị
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container my-4 flex-grow-1">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer bg-white text-muted py-3 mt-auto shadow-sm">
        <div class="container text-center small">
            &copy; 2026 - <strong>CMS Backend System</strong> - Thiết kế tối ưu bởi Hoàng Long.
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>