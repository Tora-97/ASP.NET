<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ThaiCMS Admin</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            background-color: #f8f9fa;
        }

        .sidebar {
            min-height: 100vh;
            background: linear-gradient(180deg, #1e293b 0%, #0f172a 100%);
            box-shadow: 4px 0 10px rgba(0, 0, 0, 0.05);
            position: fixed;
            top: 0;
            bottom: 0;
            left: 0;
            z-index: 100;
            overflow-y: auto;
        }

            .sidebar a {
                color: #94a3b8;
                text-decoration: none;
                display: flex;
                align-items: center;
                gap: 12px;
                padding: 12px 24px;
                font-weight: 500;
                font-size: 0.95rem;
                transition: all 0.2s ease;
                border-left: 4px solid transparent;
            }

                .sidebar a i {
                    font-size: 1.1rem;
                }

                .sidebar a:hover {
                    background-color: rgba(255, 255, 255, 0.05);
                    color: #f8fafc;
                    border-left-color: #38bdf8;
                }

            .sidebar .active-link {
                background-color: rgba(14, 165, 233, 0.15);
                color: #38bdf8;
                border-left-color: #0284c7;
                font-weight: 600;
            }

        .sidebar-heading {
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.1rem;
            font-weight: 700;
            color: #64748b;
            padding: 16px 24px 8px;
        }

        .main-content {
            margin-left: 16.66667%; /* Khớp với độ rộng col-md-2 */
        }

        @@media (max-width: 768px) {
            .sidebar {
                position: static;
                min-height: auto;
            }

            .main-content {
                margin-left: 0;
            }
        }
    </style>
</head>
<body>
    <div class="container-fluid">
        <div class="row">

            <nav class="col-md-3 col-lg-2 sidebar p-0">
                <div class="p-4 text-center border-bottom border-secondary border-opacity-25">
                    <h5 class="text-white fw-bold mb-0 tracking-wide"><i class="bi bi-cpu-fill text-info"></i> ThaiCMS Admin</h5>
                </div>

                @if (User.Identity.IsAuthenticated)
                {
                    <div class="p-3 mx-3 mt-3 bg-white bg-opacity-50 rounded-3 border border-white border-opacity-10">

                        <div class="small text-dark fw-semibold">Tài khoản:</div>

                        <div class="text-dark fw-bold text-truncate">@User.FindFirst("FullName")?.Value</div>

                        <span class="badge bg-info bg-opacity-20 text-dark small mt-1 py-1 px-2">
                            @User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value
                        </span>

                        <div class="mt-2 pt-2 border-top border-white border-opacity-10 d-grid">
                            <a class="btn btn-danger btn-sm text-white p-1 py-1 d-block text-center border-0 rounded-2"
                               style="font-size: 0.8rem; border-left: none !important;"
                               asp-controller="Account" asp-action="Logout">
                                <i class="bi bi-box-arrow-right"></i> Đăng xuất
                            </a>
                        </div>
                    </div>
                }

                <div class="mt-3">
                    <a asp-controller="Home" asp-action="Index" class="active-link">
                        <i class="bi bi-speedometer2"></i> Bảng điều khiển
                    </a>

                    <div class="sidebar-heading">Quản trị nội dung</div>
                    <a asp-controller="Category" asp-action="Index">
                        <i class="bi bi-folder2-open"></i> Quản lý Danh mục
                    </a>
                    <a asp-controller="Post" asp-action="Index">
                        <i class="bi bi-file-earmark-richtext"></i> Quản lý Bài viết
                    </a>
                    <a asp-controller="User" asp-action="Index">
                        <i class="bi bi-shield-check"></i> Quản lý Thành viên
                    </a>

                    <div class="sidebar-heading">Hệ thống bán hàng</div>
                    <a asp-controller="ProductCategory" asp-action="Index">
                        <i class="bi bi-tags"></i> Danh mục sản phẩm
                    </a>
                    <a asp-controller="Product" asp-action="Index">
                        <i class="bi bi-box-seam"></i> Quản lý Sản phẩm
                    </a>
                    <a asp-controller="Customer" asp-action="Index">
                        <i class="bi bi-person-badge"></i> Khách hàng
                    </a>
                    <a asp-controller="Order" asp-action="Index">
                        <i class="bi bi-receipt"></i> Quản lý Đơn hàng
                    </a>
                    <a asp-controller="OrderDetail" asp-action="Index">
                        <i class="bi bi-list-check"></i> Đơn hàng chi tiết
                    </a>
                </div>
            </nav>

            <main class="col-md-9 col-lg-10 main-content p-4 ms-auto">
                <div class="bg-white p-4 shadow-sm rounded-3" style="min-height: 85vh;">
                    @RenderBody()
                </div>
            </main>

        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>