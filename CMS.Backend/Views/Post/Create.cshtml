@model CMS.Data.Entities.Post
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Thêm bài viết mới";
}

<div class="container mt-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-primary text-white py-3"><h5 class="mb-0 fw-bold">THÊM BÀI VIẾT MỚI</h5></div>
        <div class="card-body p-4">
            <form asp-action="Create" method="post" enctype="multipart/form-data">
                <div class="mb-3">
                    <label class="form-label fw-semibold">Tiêu đề:</label>
                    <input asp-for="Title" class="form-control" required placeholder="Nhập tiêu đề..." />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Nội dung:</label>
                    <textarea asp-for="Content" id="editor" class="form-control"></textarea>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Ảnh bìa:</label>
                    <input type="file" name="uploadImage" id="imageInput" class="form-control" accept="image/*" />
                    <img id="imagePreview" src="https://via.placeholder.com/200x120" class="img-thumbnail mt-3" style="max-width: 250px;" />
                </div>
                <button type="submit" class="btn btn-primary fw-bold">Lưu bài viết</button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.ckeditor.com/ckeditor5/41.0.0/classic/ckeditor.js"></script>
    <script>
        ClassicEditor.create(document.querySelector('#editor'));
        document.getElementById('imageInput').addEventListener('change', function(e) {
        if(e.target.files[0]) document.getElementById('imagePreview').src = URL.createObjectURL(e.target.files[0]);
        });
    </script>
}