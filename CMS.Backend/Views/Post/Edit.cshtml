@model CMS.Data.Entities.Post
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Chỉnh sửa bài viết";
}

<div class="container mt-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-warning py-3"><h5 class="mb-0 fw-bold">CHỈNH SỬA BÀI VIẾT</h5></div>
        <div class="card-body p-4">
            <form asp-action="Edit" method="post" enctype="multipart/form-data">
                <input type="hidden" asp-for="Id" />
                <div class="mb-3">
                    <label class="form-label fw-semibold">Tiêu đề:</label>
                    <input asp-for="Title" class="form-control" required />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Nội dung:</label>
                    <textarea asp-for="Content" id="editor" class="form-control" rows="6"></textarea>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Ảnh bìa:</label>
                    <input type="file" name="uploadImage" id="imageInputEdit" class="form-control" accept="image/*" />
                    <img id="imagePreviewEdit" src="@(string.IsNullOrEmpty(Model.ImageUrl) ? "https://via.placeholder.com/200x120" : Model.ImageUrl)" class="img-thumbnail mt-3" style="max-width: 250px;" />
                </div>
                <button type="submit" class="btn btn-warning fw-bold">Cập nhật dữ liệu</button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.ckeditor.com/ckeditor5/41.0.0/classic/ckeditor.js"></script>
    <script>
        ClassicEditor.create(document.querySelector('#editor'));
        document.getElementById('imageInputEdit').addEventListener('change', function(e) {
        if(e.target.files[0]) document.getElementById('imagePreviewEdit').src = URL.createObjectURL(e.target.files[0]);
        });
    </script>
}