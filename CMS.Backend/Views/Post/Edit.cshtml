@model CMS.Data.Entities.Post
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Chỉnh sửa bài viết";
}

<div class="container mt-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-warning text-dark py-3">
            <h5 class="mb-0 fw-bold"><i class="bi bi-pencil-square me-2"></i> CHỈNH SỬA BÀI VIẾT</h5>
        </div>
        <div class="card-body p-4">
            <form asp-action="Edit" method="post" enctype="multipart/form-data">
                <input type="hidden" asp-for="Id" />

                <div class="mb-3">
                    <label class="form-label fw-semibold">Tiêu đề bài viết:</label>
                    <input asp-for="Title" class="form-control" required />
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Danh mục bài viết:</label>
                    <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.CategoryList" required></select>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Nội dung bài viết:</label>
                    <textarea asp-for="Content" class="form-control" rows="6" placeholder="Nhập nội dung chi tiết tại đây..." required></textarea>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Hình ảnh đại diện (Bấm để thay đổi):</label>
                    <input type="file" name="uploadImage" id="imageInputEdit" class="form-control" accept="image/*" />

                    <div class="mt-3">
                        <label class="small text-muted d-block mb-1">Hình ảnh hiện tại của bài viết:</label>
                        <img id="imagePreviewEdit" src="@(string.IsNullOrEmpty(Model.ImageUrl) ? "https://via.placeholder.com/200x120?text=No+Image" : Model.ImageUrl)"
                             class="img-thumbnail" style="max-width: 250px; height: auto;" />
                    </div>
                    <small class="text-danger d-block mt-1"><i class="bi bi-info-circle"></i> Nếu không muốn đổi ảnh cũ, vui lòng để trống ô chọn file này.</small>
                </div>

                <hr class="opacity-25" />
                <div class="d-flex justify-content-end gap-2">
                    <a href="/Post" class="btn btn-outline-secondary px-4">Hủy bỏ</a>
                    <button type="submit" class="btn btn-warning text-dark px-4 fw-bold">Cập nhật dữ liệu</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // JS xử lý hiển thị ảnh mới thay thế ảnh cũ ngay trên giao diện Edit
        document.getElementById('imageInputEdit').addEventListener('change', function (e) {
            const preview = document.getElementById('imagePreviewEdit');
            const file = e.target.files[0];
            if (file) {
                preview.src = URL.createObjectURL(file);
            }
        });
    </script>
}