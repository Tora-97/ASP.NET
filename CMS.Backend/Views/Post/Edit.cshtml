*@
@model CMS.Data.Entities.Post

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Cập nhật bài viết";
}

<style>
    .ck-editor__editable_inline {
        min-height: 300px;
    }
</style>

<div class="container mt-4">
    <div class="card shadow border-0" style="border-radius: 0.75rem;">
        <div class="card-header bg-warning text-dark py-3" style="border-top-left-radius: 0.75rem; border-top-right-radius: 0.75rem;">
            <h5 class="mb-0 fw-bold"><i class="bi bi-pencil-square me-2"></i> CẬP NHẬT BÀI VIẾT</h5>
        </div>
        <div class="card-body p-4">
            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="Id" />

                <div class="row g-4">
                    <div class="col-12 col-lg-8">
                        <div class="mb-3">
                            <label class="form-label fw-semibold text-secondary">Tiêu đề bài viết:</label>
                            <input asp-for="Title" class="form-control p-2 fw-bold text-dark" required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold text-secondary">Nội dung chi tiết:</label>
                            <textarea asp-for="Content" class="form-control" rows="10"></textarea>
                        </div>
                    </div>

                    <div class="col-12 col-lg-4">
                        <div class="card bg-light border-0 p-3" style="border-radius: 0.5rem;">
                            <div class="mb-3">
                                <label class="form-label fw-semibold text-secondary">Chuyên mục:</label>
                                <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.CategoryList" required></select>
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-semibold text-secondary">Link ảnh đại diện (URL):</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-white text-muted"><i class="bi bi-image"></i></span>
                                    <input asp-for="ImageUrl" class="form-control" />
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-semibold text-secondary">Ngày đăng:</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-white text-muted"><i class="bi bi-calendar-event"></i></span>
                                    <input asp-for="CreatedDate" type="date" class="form-control" value="@Model?.CreatedDate.ToString("yyyy-MM-dd")" required />
                                </div>
                            </div>

                            <hr class="opacity-25" />

                            <div class="d-grid gap-2">
                                <button type="submit" class="btn btn-warning text-dark fw-bold py-2 shadow-sm">
                                    <i class="bi bi-check-circle-fill"></i> Lưu các thay đổi
                                </button>
                                <a asp-action="Index" class="btn btn-outline-secondary fw-semibold py-2">
                                    <i class="bi bi-x-circle"></i> Hủy chỉnh sửa
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.ckeditor.com/ckeditor5/39.0.1/classic/ckeditor.js"></script>
    <script>
        ClassicEditor
            .create(document.querySelector('#Content'))
            .catch(error => {
                console.error(error);
            });
    </script>
}