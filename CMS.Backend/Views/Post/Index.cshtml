@model IEnumerable<CMS.Data.Entities.Post>
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Quản lý bài viết";
}

<style>
    .admin-post-card {
        transition: all 0.2s ease-in-out;
        border-radius: 0.5rem;
    }

        .admin-post-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 15px rgba(0,0,0,0.08) !important;
        }

    .card-img-fixed {
        height: 180px;
        object-fit: cover;
    }
</style>

<div class="container mt-4">
    <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-center border-bottom pb-3 mb-4 gap-2">
        <div>
            <h3 class="text-dark fw-bold mb-1"><i class="bi bi-file-earmark-richtext text-primary"></i> QUẢN LÝ BÀI VIẾT</h3>
            <p class="text-muted small mb-0">Hệ thống danh sách tin tức biên tập viên toàn trang</p>
        </div>
        <a asp-action="Create" class="btn btn-success fw-semibold shadow-sm align-self-start align-self-sm-center">
            <i class="bi bi-plus-circle-fill"></i> Thêm bài viết mới
        </a>
    </div>

    <div class="row g-4">
        @if (!Model.Any())
        {
            <div class="col-12 text-center py-5 bg-white shadow-sm rounded-3">
                <i class="bi bi-journal-x text-muted fs-1 d-block mb-2"></i>
                <span class="text-secondary">Chưa có bài viết nào được đăng tải trong hệ thống.</span>
            </div>
        }
        else
        {
            @foreach (var item in Model)
            {
                <div class="col-12 col-md-6 col-lg-4">
                    <div class="card admin-post-card shadow-sm h-100 border-0 bg-white border border-light">

                        <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "https://via.placeholder.com/600x300" : item.ImageUrl)"
                             class="card-img-top card-img-fixed"
                             alt="Thumbnail">

                        <div class="card-body d-flex flex-column p-3.5">
                            <span class="badge bg-info text-dark align-self-start mb-2 fw-semibold px-2 py-1">
                                <i class="bi bi-tag-fill me-1"></i> @item.Category?.Name
                            </span>

                            <h6 class="card-title fw-bold text-dark text-truncate-2 mb-2" style="min-height: 42px; line-height: 1.4;">
                                @item.Title
                            </h6>

                            <div class="card-text text-muted small text-truncate mb-3">
                                @Html.Raw(item.Content)
                            </div>

                            <p class="text-muted tracking-wide" style="font-size: 0.75rem; margin-top: auto;">
                                <i class="bi bi-calendar3"></i> Ngày đăng: @item.CreatedDate.ToString("dd/MM/yyyy")
                            </p>

                            <hr class="opacity-10 my-2" />

                            <div class="d-flex gap-1 mt-1">
                                <a href="/Post/Details/@item.Id" class="btn btn-info btn-sm text-dark fw-semibold me-1">
                                    <i class="bi bi-eye"></i> Xem
                                </a>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning flex-fill fw-medium">
                                    <i class="bi bi-pencil"></i> Sửa
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.Id"
                                   class="btn btn-sm btn-outline-danger flex-fill fw-medium"
                                   onclick="return confirm('Chúng ta có chắc chắn muốn xóa bài viết 【@item.Title】 này không?')">
                                    <i class="bi bi-trash"></i> Xóa
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>