@model CMS.Data.Entities.Post
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Chi tiết bài viết";
    string imgUrl = Model.ImageUrl ?? "";
    string finalSrc = imgUrl.StartsWith("http") ? imgUrl : (string.IsNullOrEmpty(imgUrl) ? "/uploads/banner.jpg" : "/uploads/" + imgUrl);
}

<div class="container mt-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-info text-white py-3 d-flex justify-content-between align-items-center">
            <h5 class="mb-0 fw-bold"><i class="bi bi-eye-fill me-2"></i> CHI TIẾT BÀI VIẾT</h5>
            <span class="badge bg-white text-dark fw-semibold px-3 py-2">ID: #@Model.Id</span>
        </div>
        <div class="card-body p-4">
            <div class="row g-4">
                <div class="col-md-4 text-center">
                    <img src="@finalSrc" class="img-fluid rounded shadow-sm border" alt="Ảnh bài viết" style="max-height: 250px; width:100%; object-fit: cover;" onerror="this.src='/uploads/banner.jpg'" />
                </div>
                <div class="col-md-8">
                    <h3 class="fw-bold text-dark mb-3">@Model.Title</h3>
                    <div class="mb-3">
                        <span class="badge bg-primary text-white p-2">Danh mục: @(Model.Category?.Name ?? "Chưa phân loại")</span>
                    </div>
                    <div class="bg-light p-3 rounded text-secondary">
                        @Html.Raw(Model.Content)
                    </div>
                </div>
            </div>
        </div>
        <div class="card-footer bg-white border-0 d-flex justify-content-end gap-2 p-3">
            <a href="/Post/Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Quay lại</a>
            <a href="/Post/Edit/@Model.Id" class="btn btn-warning"><i class="bi bi-pencil"></i> Chỉnh sửa</a>
        </div>
    </div>
</div>