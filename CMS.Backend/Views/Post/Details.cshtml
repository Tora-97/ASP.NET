@model CMS.Data.Entities.Post
@{
    Layout = "_Layout";
    ViewData["Title"] = Model?.Title;
}

<div class="container mt-5">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb bg-light p-2 px-3 rounded-3 shadow-sm">
            <li class="breadcrumb-item"><a href="/Post" class="text-decoration-none text-muted"><i class="bi bi-house-door-fill"></i> Tin tức</a></li>
            <li class="breadcrumb-item active text-dark" aria-current="page">Chi tiết bài viết</li>
        </ol>
    </nav>

    <div class="row justify-content-center">
        <div class="col-12 col-lg-9">

            <header class="mb-4">
                <h1 class="display-5 fw-bold text-dark mb-3">@Model.Title</h1>
                <div class="d-flex flex-wrap align-items-center gap-3 text-muted small">
                    <span class="badge bg-danger px-2 py-1.5 fw-semibold" style="border-radius: 0.4rem;">
                        <i class="bi bi-bookmark-fill"></i> @Model.Category?.Name
                    </span>
                    <span><i class="bi bi-clock-history"></i> Đăng lúc: @Model.CreatedDate.ToString("dd/MM/yyyy HH:mm")</span>
                </div>
            </header>

            <hr class="opacity-25 my-4" />

            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <div class="text-center mb-5">
                    <img src="@Model.ImageUrl" class="img-fluid rounded-3 shadow-sm w-100" alt="@Model.Title" style="max-height: 450px; object-fit: cover;">
                </div>
            }

            <div class="post-content fs-5 text-dark lh-base mb-5" style="text-align: justify; letter-spacing: -0.01rem;">
                @Html.Raw(Model.Content)
            </div>

            <div class="mt-5 border-top pt-4">
                <a href="/Post" class="btn btn-outline-secondary px-4 fw-semibold shadow-sm" style="border-radius: 0.5rem;">
                    <i class="bi bi-arrow-left-short fs-5 align-middle"></i> Quay lại danh sách tin
                </a>
            </div>

        </div>
    </div>
</div>