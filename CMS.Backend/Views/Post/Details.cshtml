@model CMS.Data.Entities.Post
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Chi tiết bài viết";
}

<div class="container mt-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-info text-dark py-3 d-flex justify-content-between align-items-center">
            <h5 class="mb-0 fw-bold"><i class="bi bi-eye-fill me-2"></i> CHI TIẾT BÀI VIẾT</h5>
            <span class="badge bg-white text-dark fw-semibold px-3 py-2">Mã ID: #@Model.Id</span>
        </div>

        <div class="card-body p-4">
            <div class="row g-4">
                <div class="col-12 col-md-4 text-center border-end border-light">
                    <label class="form-label d-block fw-bold text-secondary text-uppercase small mb-2">Hình ảnh đại diện</label>
                    <img src="@(string.IsNullOrEmpty(Model.ImageUrl) ? "https://via.placeholder.com/350x220?text=No+Image" : Model.ImageUrl)"
                         class="img-fluid rounded-3 shadow-sm border"
                         alt="Ảnh đại diện bài viết"
                         style="max-height: 250px; object-fit: cover;" />
                </div>

                <div class="col-12 col-md-8">
                    <div class="mb-3">
                        <label class="small text-muted fw-semibold d-block text-uppercase">Tiêu đề tin tức:</label>
                        <h3 class="fw-bold text-dark">@Model.Title</h3>
                    </div>

                    <div class="mb-3">
                        <label class="small text-muted fw-semibold d-block text-uppercase">Thuộc danh mục:</label>
                        <span class="badge bg-primary bg-opacity-10 text-primary px-3 py-2 fs-6 fw-semibold rounded-2">
                            <i class="bi bi-folder2-open me-1"></i> @(Model.Category?.Name ?? "Chưa phân loại")
                        </span>
                    </div>

                    @if (Html.ViewData.ModelMetadata.Properties.Any(p => p.PropertyName == "Description"))
                    {
                        <div class="mb-3 pt-2 border-top border-light">
                            <label class="small text-muted fw-semibold d-block text-uppercase">Mô tả tóm tắt:</label>
                            <p class="text-secondary lh-base">@Html.Raw(Model.GetType().GetProperty("Description")?.GetValue(Model, null))</p>
                        </div>
                    }
                </div>
            </div>

            <hr class="opacity-25 my-4" />
            <div class="d-flex justify-content-end gap-2">
                <a href="/Post" class="btn btn-outline-secondary px-4"><i class="bi bi-arrow-left"></i> Quay lại danh sách</a>
                <a href="/Post/Edit/@Model.Id" class="btn btn-warning text-dark fw-bold px-4"><i class="bi bi-pencil-square"></i> Chỉnh sửa bài này</a>
            </div>
        </div>
    </div>
</div>