@model IEnumerable<CMS.Data.Entities.Order>
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Quản lý Đơn hàng";
}

<div class="container-fluid mt-4">
    <h3 class="fw-bold text-dark mb-4"><i class="bi bi-receipt me-2 text-primary"></i> QUẢN LÝ ĐƠN HÀNG</h3>
    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light text-uppercase small">
                    <tr>
                        <th class="py-3 ps-4">Mã ĐH</th>
                        <th>Khách Hàng</th>
                        <th>Ngày Đặt</th>
                        <th>Trạng Thái</th>
                        <th class="text-center">Chi Tiết</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4 fw-bold text-primary">#@item.Id</td>
                            <td>@item.Customer?.FullName</td>
                            <td>@item.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>
                                <form action="/Order/UpdateStatus/@item.Id" method="post" class="d-flex gap-2">
                                    <select name="status" class="form-select form-select-sm w-auto" onchange="this.form.submit()">
                                        <option value="0" selected="@(item.Status == 0)">Chờ duyệt</option>
                                        <option value="1" selected="@(item.Status == 1)">Đang giao</option>
                                        <option value="2" selected="@(item.Status == 2)">Đã xong</option>
                                    </select>
                                </form>
                            </td>
                            <td class="text-center">
                                <a href="/OrderDetail/Index/@item.Id" class="btn btn-sm btn-info text-white"><i class="bi bi-eye"></i></a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>